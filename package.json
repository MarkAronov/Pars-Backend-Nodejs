{
  "name": "pars-backend-nodejs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "env-cmd -f ./config/dev.env nodemon ./src/bin/www --exec \"npm run lint && node\"",
    "lint": "eslint \"**/*.js\"",
    "test": "env-cmd -f ./config/test.env jest --watchAll --detectOpenHandles --silent=false"
  },
  "jest": {
    "testEnvironment": "node"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "debug": "^4.3.2",
    "express": "~4.16.1",
    "jsonwebtoken": "^8.5.1",
    "mongodb": "^4.1.4",
    "mongoose": "^6.0.12",
    "mongoose-unique-validator": "^2.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.3",
    "sharp": "^0.29.2",
    "validator": "^13.7.0"
  },
  "eslintConfig": {
    "extends": "airbnb-base",
    "env": {
      "es6": true,
      "browser": true
    },
    "rules": {
      "brace-style": [
        "error",
        "stroustrup"
      ],
      "comma-dangle": [
        "error",
        "never"
      ],
      "no-unused-vars": [
        "warn"
      ],
      "no-var": [
        "off"
      ],
      "one-var": [
        "off"
      ]
    }
  },
  "devDependencies": {
    "env-cmd": "^10.1.0",
    "eslint": "^8.10.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^8.4.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.0.0",
    "jest": "^27.3.1",
    "nodemon": "^2.0.14",
    "prettier": "^2.5.1",
    "supertest": "^6.1.6"
  }
}
